# =============================================================================
# Apex Decision Engine — Frontend Environment Variables
# Source of truth for Vercel deployment.
#
# USAGE (local dev):
#   cp .env.example .env.local
#   Fill in each value. Never commit .env.local.
#
# USAGE (Vercel):
#   Set each variable in Vercel Dashboard → Project → Settings → Environment Variables
#   Select "Production" (and "Preview" if wanted).
#
# All variables MUST be prefixed with VITE_ to be accessible in the browser.
# =============================================================================


# ── Supabase ─────────────────────────────────────────────────────────────────
# Supabase Dashboard → Settings → API

# Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe to expose in the browser (protected by Row Level Security)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── Backend API ───────────────────────────────────────────────────────────────
# URL of your Render backend service (no trailing slash)
# In local dev this is proxied automatically — only needed for production builds
VITE_API_URL=https://apex-decision-engine.onrender.com


# ── App URL ───────────────────────────────────────────────────────────────────
# The URL of this frontend. Used for Supabase auth redirect URLs.
# Must match exactly the "Site URL" in Supabase Auth → URL Configuration.
VITE_APP_URL=https://apex-decision-engine.vercel.app


# ── Monitoring ────────────────────────────────────────────────────────────────
# Sentry DSN for frontend error tracking — sentry.io → Project → Settings → DSN
# Leave blank to disable Sentry (optional)
VITE_SENTRY_DSN=


# ── Stripe (optional) ─────────────────────────────────────────────────────────
# Publishable key — safe for browser (Stripe Dashboard → Developers → API Keys)
# Only needed if using Stripe.js embedded checkout. Current implementation
# uses redirect-only checkout via the backend, so this is optional.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
