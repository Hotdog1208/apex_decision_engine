# Copy to .env and fill in values. Do not commit .env.

# --- Chat AI (recommended for full AI assistant) ---
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: model for chat (default: gpt-4o-mini)
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Live market data: yahoo = real quotes/charts/screener/heatmap (no key). mock = JSON only. ---
DATA_SOURCE=yahoo

# --- News + economic calendar (free key at https://finnhub.io/register) ---
FINNHUB_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20240620

# --- Production auth (optional for dev) ---
# ADE_SECRET_KEY=your-random-secret-here

# --- E*TRADE (optional; for live broker) ---
# Set DATA_SOURCE=etrade when ready. See engine/api/etrade_connector.py
