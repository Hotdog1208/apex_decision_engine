# =============================================================================
# Apex Decision Engine — Backend Environment Variables
# Source of truth for Render deployment.
#
# USAGE:
#   cp .env.example .env
#   Fill in each value. Never commit .env.
#
# REQUIRED vs OPTIONAL:
#   Lines without a trailing "(optional)" comment are REQUIRED for the app to
#   function correctly in production.
# =============================================================================


# ── Supabase ─────────────────────────────────────────────────────────────────
# Supabase Dashboard → Settings → API

# Project URL (e.g. https://xyzxyz.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# JWT Secret — used to validate user tokens on every API request
# Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Service Role Key — server-side only, never expose to browser
# Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Anthropic Console → API Keys → Create key
ANTHROPIC_API_KEY=sk-ant-api03-...

# Model to use for signal generation, PRISM chat, and CIPHER
# Latest recommended: claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514


# ── Stripe ───────────────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API Keys → Secret key
STRIPE_SECRET_KEY=sk_live_...

# Stripe Dashboard → Developers → Webhooks → signing secret (whsec_...)
# Created when you add the webhook endpoint pointing to /stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — Stripe Dashboard → Products → [each plan] → copy Price ID
STRIPE_PRICE_EDGE=price_...
STRIPE_PRICE_ALPHA=price_...
STRIPE_PRICE_APEX=price_...


# ── App URL ───────────────────────────────────────────────────────────────────
# The production frontend URL. Used in Stripe redirect URLs.
# Must NOT have a trailing slash.
APP_URL=https://apex-decision-engine.vercel.app


# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. No wildcards in production.
# Add your Vercel preview URL if you want preview deploys to work.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://apex-decision-engine.vercel.app


# ── Market Data ───────────────────────────────────────────────────────────────
# Data source for price/quote fetching.
# Options: yahoo (default, free), mock (fixtures only, no network)
DATA_SOURCE=yahoo

# Finnhub API key — used for news, options flow, and economic calendar
# Free tier available at https://finnhub.io/register
FINNHUB_API_KEY=


# ── Admin ────────────────────────────────────────────────────────────────────
# Protects /admin/set-tier, /admin/events, and /admin/accuracy/sweep
# Set to any strong random string (e.g. openssl rand -hex 32)
ADMIN_SECRET_KEY=your-random-32-char-admin-key


# ── Monitoring ────────────────────────────────────────────────────────────────
# Sentry DSN for backend error tracking — sentry.io → Project → Settings → DSN
# Leave blank to disable Sentry (optional)
SENTRY_DSN=


# ── Server ────────────────────────────────────────────────────────────────────
# Render injects $PORT automatically — you generally do not set this manually
PORT=8000

# ── Optional / Advanced ───────────────────────────────────────────────────────
# Override local paper trade log path (defaults to data/paper_trade_log.json)
# PAPER_LOG_PATH=data/paper_trade_log.json

# E*TRADE broker integration (optional — for live order execution, not signal gen)
# Set DATA_SOURCE=etrade when enabling
# ETRADE_CONSUMER_KEY=
# ETRADE_CONSUMER_SECRET=
# ETRADE_BASE_URL=https://apisb.etrade.com
